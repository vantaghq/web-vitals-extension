{
  "env": {
    "browser": true,
    "es2020": true,
    "webextensions": true
  },
  "extends": ["eslint:recommended"],
  "parser": "babel-eslint",
  "parserOptions": {
    "ecmaVersion": 2020,
    "sourceType": "module"
  },
  "globals": {
    "chrome": "readonly",
    "_": "readonly"
  },
  "ignorePatterns": ["src/browser_action/web-vitals.js", "src/browser_action/lodash-debounce-custom.js"],
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-undef": "error",
    "eqeqeq": ["error", "always"],
    "no-var": "warn",
    "prefer-const": "warn"
  }
}
